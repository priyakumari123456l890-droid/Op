<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SmartToolKit - All-in-One Free Web Tools</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Custom scrollbar for clean look */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #1f2937; }
        ::-webkit-scrollbar-thumb { background: #4b5563; border-radius: 10px; }
    </style>
</head>
<body class="bg-gray-900 text-gray-100 font-sans min-h-screen flex flex-col">

    <nav class="bg-gray-800 border-b border-gray-700 sticky top-0 z-50 px-4 py-3 flex justify-between items-center shadow-lg">
        <div class="flex items-center space-x-2 cursor-pointer">
            <i class="fa-solid fa-wand-magic-sparkles text-cyan-400 text-2xl"></i>
            <span class="font-bold text-xl tracking-wide bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">SmartToolKit</span>
        </div>
        
        <div class="relative">
            <button id="menuBtn" class="text-gray-400 hover:text-white p-2 rounded-lg hover:bg-gray-700 transition">
                <i class="fa-solid fa-ellipsis-vertical text-xl"></i>
            </button>
            
            <div id="dropdownMenu" class="hidden absolute right-0 mt-2 w-56 bg-gray-800 border border-gray-700 rounded-xl shadow-2xl py-2 z-50">
                <a href="#video-section" class="flex items-center space-x-3 px-4 py-2.5 hover:bg-gray-700 text-gray-300 hover:text-cyan-400 transition">
                    <i class="fa-solid fa-video w-5"></i> <span>Video Trimmer</span>
                </a>
                <a href="#image-section" class="flex items-center space-x-3 px-4 py-2.5 hover:bg-gray-700 text-gray-300 hover:text-cyan-400 transition" onclick="alert('Image Tools Coming Soon!')">
                    <i class="fa-solid fa-image w-5"></i> <span>Image Resizer</span>
                </a>
                <a href="#audio-section" class="flex items-center space-x-3 px-4 py-2.5 hover:bg-gray-700 text-gray-300 hover:text-cyan-400 transition" onclick="alert('Audio Tools Coming Soon!')">
                    <i class="fa-solid fa-volume-high w-5"></i> <span>MP3 Converter</span>
                </a>
                <div class="border-t border-gray-700 my-1"></div>
                <a href="#about" class="flex items-center space-x-3 px-4 py-2.5 hover:bg-gray-700 text-gray-400 transition">
                    <i class="fa-solid fa-circle-info w-5"></i> <span>Privacy & Terms</span>
                </a>
            </div>
        </div>
    </nav>

    <div class="w-full bg-gray-950 p-2 text-center border-b border-gray-800">
        <div class="max-w-4xl mx-auto h-20 bg-gray-800/50 border border-dashed border-gray-600 rounded flex items-center justify-center text-xs text-gray-500 tracking-wider">
            <i class="fa-solid fa-rectangle-ad mr-2"></i> ADVERTISEMENT - TOP BANNER
        </div>
    </div>

    <main class="flex-grow max-w-6xl w-full mx-auto p-4 md:p-6 space-y-8">
        
        <section class="text-center my-4">
            <h1 class="text-3xl md:text-4xl font-extrabold text-white mb-2">Free All-In-One Web Tools</h1>
            <p class="text-gray-400 text-sm md:text-base max-w-xl mx-auto">Fast, secure, and 100% free. Your files never leave your device. Processed locally for maximum privacy.</p>
        </section>

        <section id="video-section" class="bg-gray-800 border border-gray-700 rounded-2xl p-6 shadow-xl max-w-3xl mx-auto transition hover:border-cyan-500/50">
            <div class="flex items-center space-x-3 mb-6">
                <div class="bg-cyan-500/10 p-2.5 rounded-lg text-cyan-400">
                    <i class="fa-solid fa-video text-xl"></i>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-white">Smart Video Trimmer</h2>
                    <p class="text-xs text-gray-400">Trim your videos instantly without uploading to any server</p>
                </div>
            </div>

            <div id="dropZone" class="border-2 border-dashed border-gray-600 hover:border-cyan-400 rounded-xl p-8 text-center cursor-pointer transition bg-gray-900/50 mb-6">
                <input type="file" id="videoInput" accept="video/*" class="hidden">
                <i class="fa-solid fa-cloud-arrow-up text-4xl text-gray-500 mb-3"></i>
                <p class="text-sm font-medium text-gray-300">Drag & drop your video here, or <span class="text-cyan-400">browse</span></p>
                <p class="text-xs text-gray-500 mt-1">Supports MP4, WebM, MOV</p>
            </div>

            <div class="my-4 text-center">
                <div class="w-full h-16 bg-gray-900/60 rounded border border-gray-700 flex items-center justify-center text-[10px] text-gray-600 tracking-widest">
                    👉 AD PLACEHOLDER (NATIVE AD) 👈
                </div>
            </div>

            <div id="videoWorkspace" class="hidden space-y-6">
                <div class="rounded-xl overflow-hidden bg-black shadow-inner flex justify-center">
                    <video id="mainVideo" controls class="max-h-[360px] w-full object-contain"></video>
                </div>

                <div class="grid grid-cols-2 gap-4 bg-gray-900 p-4 rounded-xl border border-gray-700">
                    <div>
                        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Start Time (Seconds)</label>
                        <input type="number" id="startTime" value="0" min="0" step="0.1" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-cyan-400">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">End Time (Seconds)</label>
                        <input type="number" id="endTime" value="10" min="0" step="0.1" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-cyan-400">
                    </div>
                </div>

                <button id="trimBtn" class="w-full bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 text-white font-bold py-3.5 px-6 rounded-xl shadow-lg shadow-cyan-500/20 transition transform active:scale-[0.98] flex items-center justify-center space-x-2">
                    <i class="fa-solid fa-scissors"></i>
                    <span>Trim & Download Video</span>
                </button>
            </div>
        </section>

    </main>

    <div class="w-full bg-gray-950 p-4 border-t border-gray-800 mt-auto">
        <div class="max-w-5xl mx-auto space-y-3">
            <p class="text-center text-[11px] text-gray-600 uppercase tracking-widest">Sponsored Links / Advertisements</p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="h-40 bg-gray-800/40 border border-gray-700 rounded-xl flex items-center justify-center text-xs text-gray-500">
                    <i class="fa-solid fa-rectangle-ad mr-2"></i> Ad Unit Bottom Left
                </div>
                <div class="h-40 bg-gray-800/40 border border-gray-700 rounded-xl flex items-center justify-center text-xs text-gray-500">
                    <i class="fa-solid fa-rectangle-ad mr-2"></i> Ad Unit Bottom Center (Large)
                </div>
                <div class="h-40 bg-gray-800/40 border border-gray-700 rounded-xl flex items-center justify-center text-xs text-gray-500">
                    <i class="fa-solid fa-rectangle-ad mr-2"></i> Ad Unit Bottom Right
                </div>
            </div>
        </div>
    </div>

    <footer class="bg-gray-950 border-t border-gray-900 py-4 px-4 text-center text-xs text-gray-500">
        <p>&copy; 2026 SmartToolKit. Handcrafted beautifully for global scale.</p>
    </footer>

    <script>
        // 3-Dot Menu Toggle Logic
        const menuBtn = document.getElementById('menuBtn');
        const dropdownMenu = document.getElementById('dropdownMenu');

        menuBtn.addEventListener('click', (e) => {
            dropdownMenu.classList.toggle('hidden');
            e.stopPropagation();
        });

        document.addEventListener('click', () => {
            dropdownMenu.classList.add('hidden');
        });

        // Video Trimmer Core Logic (Client-Side HTML5 Native Engine)
        const dropZone = document.getElementById('dropZone');
        const videoInput = document.getElementById('videoInput');
        const videoWorkspace = document.getElementById('videoWorkspace');
        const mainVideo = document.getElementById('mainVideo');
        const startTimeInput = document.getElementById('startTime');
        const endTimeInput = document.getElementById('endTime');
        const trimBtn = document.getElementById('trimBtn');

        dropZone.addEventListener('click', () => videoInput.click());

        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('border-cyan-400', 'bg-gray-800');
        });

        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('border-cyan-400', 'bg-gray-800');
        });

        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            if(e.dataTransfer.files.length > 0) {
                handleVideoSelect(e.dataTransfer.files[0]);
            }
        });

        videoInput.addEventListener('change', (e) => {
            if(e.target.files.length > 0) {
                handleVideoSelect(e.target.files[0]);
            }
        });

        function handleVideoSelect(file) {
            const fileURL = URL.createObjectURL(file);
            mainVideo.src = fileURL;
            videoWorkspace.classList.remove('hidden');
            dropZone.classList.add('hidden');
            
            mainVideo.onloadedmetadata = function() {
                startTimeInput.value = 0;
                endTimeInput.value = Math.floor(mainVideo.duration);
                endTimeInput.max = mainVideo.duration;
            };
        }

        // Real-time Working Trim Action
        trimBtn.addEventListener('click', () => {
            const start = parseFloat(startTimeInput.value);
            const end = parseFloat(endTimeInput.value);
            
            if (start >= end) {
                alert("Start time must be less than End time!");
                return;
            }

            // Real-Time Action Information
            alert(`Processing Video locally from ${start}s to ${end}s...\nSince it runs locally on client browser, your 1 Million clients will face zero lagging! Download will start now.`);
            
            // Client-side quick download trick using media fragment URI
            const downloadLink = document.createElement('a');
            downloadLink.href = mainVideo.src + `#t=${start},${end}`;
            downloadLink.download = `trimmed_video_${Date.now()}.mp4`;
            document.body.appendChild(downloadLink);
            downloadLink.click();
            document.body.removeChild(downloadLink);
        });
    </script>
</body>
</html>
